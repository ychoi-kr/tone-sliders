# Tone Sliders — provider keys
# 여기 값을 채우고 .env.local로 복사하세요.
# UI에서 사용자 키를 입력하면 환경변수 키보다 우선합니다.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# Ollama (로컬·원격). 원격 Ollama 서버를 쓸 경우 해당 주소로 변경
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI 호환 사용자 정의 (선택)
# CUSTOM_OPENAI_BASE_URL=
# CUSTOM_OPENAI_API_KEY=
# CUSTOM_OPENAI_LABEL=OpenRouter
